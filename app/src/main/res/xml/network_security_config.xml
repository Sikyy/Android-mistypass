<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Deny cleartext globally in production -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        TODO: Enable certificate pinning once api.mistyislet.com TLS cert is stable.
        Generate the pin hash with:
            openssl s_client -connect api.mistyislet.com:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | openssl enc -base64
        Then uncomment below and replace placeholders with real hashes.
    -->
    <!--
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.mistyislet.com</domain>
        <pin-set expiration="2027-06-01">
            <pin digest="SHA-256">REPLACE_WITH_PRIMARY_PIN_HASH=</pin>
            <pin digest="SHA-256">REPLACE_WITH_BACKUP_PIN_HASH=</pin>
        </pin-set>
    </domain-config>
    -->

    <!-- Debug: allow cleartext for local development only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
